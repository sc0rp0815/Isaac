ISAAC_OWNER=Steffen

# Lokaler Haupt-Orchestrator
ACTIVE_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:latest

# OpenRouter als externer Modellpool für Decomposer / Spezialrouten
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_NEMOTRON=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_STEP=stepfun/step-3.5-flash:free
OPENROUTER_MODEL_TRINITY=arcee-ai/trinity-large-preview
OPENROUTER_MODEL_LIQUID_THINKING=liquid/lfm-2.5-1.2b-thinking:free
OPENROUTER_MODEL_LIQUID_INSTRUCT=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Isaac

# Weitere optionale Provider
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
HF_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=

# Dashboard / Limits
MONITOR_PORT=8765
DASHBOARD_PORT=8766
MIN_REQUEST_INTERVAL=2.0
MAX_RETRIES=3
MAX_CONTEXT_CHARS=3000

# Rollenmapping für OpenRouter im Decomposer
# NEMOTRON: schwere Analyse / Synthese
# STEP: schnelle Fakten / Recherchefragmente
# TRINITY: kreative Alternativperspektive
# LIQUID_THINKING: tieferes Reasoning
# LIQUID_INSTRUCT: Planung / direkte Instruktionen / Code
